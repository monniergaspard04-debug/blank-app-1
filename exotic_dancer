            winning_number,
            straight_numbers,
            straight_stake,
            outside_bets,
            outside_stake,
        )
        net = total_return - total_bet

        st.session_state.bankroll += net
        st.session_state.last_number = winning_number
        st.session_state.last_color = get_color(winning_number)
        st.session_state.last_total_bet = total_bet
        st.session_state.last_total_return = total_return
        st.session_state.last_net = net
        st.session_state.spins += 1
