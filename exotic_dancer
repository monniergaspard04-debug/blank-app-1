    outside_stake = int(st.session_state.outside_stake)
    total_bet = len(straight_numbers) * straight_stake + len(outside_bets) * outside_stake

    if total_bet <= 0:
        st.session_state.last_result = "No bets selected."
    elif total_bet > st.session_state.bankroll:
        st.session_state.last_result = "Insufficient bankroll to cover all bets."
    else:
