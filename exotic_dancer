        del st.session_state[key]
    init_state()


def number_chip_label(number: int) -> str:
    if number == 0:
        return f"🟢 {number}"
    if number in RED_NUMBERS:
        return f"🔴 {number}"
    return f"⚫ {number}"


def render_number_button(number: int, winning_number: int | None) -> None:
    color = get_color(number)
    selected = number in st.session_state.selected_numbers
    won = number == winning_number
    label = number_chip_label(number)
    if selected:
        label = f"● {label}"
    if won:
        label = f"★ {label}"
    button_type = "primary" if selected or won else "secondary"
    help_text = f"{color} - click to {'remove' if selected else 'add'} this bet"
    st.button(
        label,
        key=f"num_{number}",
        use_container_width=True,
        type=button_type,
        on_click=toggle_number,
        args=(number,),
        help=help_text,
    )


def render_outside_button(name: str) -> None:
    selected = name in st.session_state.selected_outside_bets
    label = OUTSIDE_LABELS[name]
    if selected:
        label = f"● {label}"
    button_type = "primary" if selected else "secondary"
    st.button(
        label,
        key=f"outside_{name}",
        use_container_width=True,
        type=button_type,
        on_click=toggle_outside,
        args=(name,),
    )


