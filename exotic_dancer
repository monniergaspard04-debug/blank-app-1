def get_color(number: int) -> str:
    if number == 0:
        return "Green"
    if number in RED_NUMBERS:
        return "Red"
    return "Black"


def spin_wheel() -> int:
    return random.choice(WHEEL_ORDER)


def toggle_number(number: int) -> None:
    selected = set(st.session_state.selected_numbers)
    if number in selected:
        selected.remove(number)
    else:
        selected.add(number)
    st.session_state.selected_numbers = sorted(selected)


def toggle_outside(name: str) -> None:
    selected = list(st.session_state.selected_outside_bets)
    if name in selected:
        selected.remove(name)
    else:
        selected.append(name)
    st.session_state.selected_outside_bets = selected


def evaluate_outside_bet(name: str, number: int) -> bool:
    if name == "Red":
        return number in RED_NUMBERS
    if name == "Black":
        return number in BLACK_NUMBERS
    if name == "Even":
        return number != 0 and number % 2 == 0
    if name == "Odd":
        return number % 2 == 1
    if name == "1-18":
        return 1 <= number <= 18
    if name == "19-36":
        return 19 <= number <= 36
    if name == "1st Dozen":
        return 1 <= number <= 12
    if name == "2nd Dozen":
        return 13 <= number <= 24
    if name == "3rd Dozen":
        return 25 <= number <= 36
    if name == "Column 1":
        return number != 0 and (number - 1) % 3 == 0
    if name == "Column 2":
        return number != 0 and (number - 2) % 3 == 0
    if name == "Column 3":
        return number != 0 and number % 3 == 0
    return False


def resolve_spin(
    number: int,
    straight_numbers: list[int],
    straight_stake: int,
    outside_bets: list[str],
    outside_stake: int,
) -> tuple[int, list[str], int]:
    total_return = 0
    winning_bets: list[str] = []
    total_bet = len(straight_numbers) * straight_stake + len(outside_bets) * outside_stake

    for selected in straight_numbers:
        if selected == number:
            total_return += straight_stake * 36
            winning_bets.append(f"Number {selected} x35")

    for bet_name in outside_bets:
        if evaluate_outside_bet(bet_name, number):
            payout = OUTSIDE_PAYOUTS[bet_name]
            total_return += outside_stake * (payout + 1)
            winning_bets.append(f"{OUTSIDE_LABELS[bet_name]} x{payout}")

    return total_return, winning_bets, total_bet


def compute_win_probabilities(
    straight_numbers: list[int],
    straight_stake: int,
    outside_bets: list[str],
    outside_stake: int,
) -> tuple[float, float, int]:
    total_bet = len(straight_numbers) * straight_stake + len(outside_bets) * outside_stake
    if total_bet <= 0:
        return 0.0, 0.0, 0

    hit_count = 0
    profit_count = 0

    for number in range(37):
        total_return, winning_bets, _ = resolve_spin(
            number,
            straight_numbers,
            straight_stake,
            outside_bets,
            outside_stake,
        )
        if winning_bets:
            hit_count += 1
        if total_return - total_bet > 0:
            profit_count += 1

    return (hit_count / 37) * 100, (profit_count / 37) * 100, total_bet


def compute_expected_net_per_spin(
    straight_numbers: list[int],
    straight_stake: int,
    outside_bets: list[str],
    outside_stake: int,
) -> tuple[float, float]:
    total_bet = len(straight_numbers) * straight_stake + len(outside_bets) * outside_stake
    if total_bet <= 0:
        return 0.0, 0.0

    total_net = 0.0
    for number in range(37):
        total_return, _, _ = resolve_spin(
            number,
            straight_numbers,
            straight_stake,
            outside_bets,
            outside_stake,
        )
        total_net += (total_return - total_bet)

    expected_net = total_net / 37
    house_edge_pct = 0.0 if total_bet == 0 else (-expected_net / total_bet) * 100
    return expected_net, house_edge_pct


def strategy_to_bets(
    strategy: str,
    current_numbers: list[int],
    current_outside_bets: list[str],
    straight_stake: int,
    outside_stake: int,
) -> tuple[list[int], list[str], int, int]:
    if strategy == "Current selection":
        return current_numbers, current_outside_bets, straight_stake, outside_stake
    if strategy == "Red only":
        return [], ["Red"], straight_stake, outside_stake
    if strategy == "Black only":
        return [], ["Black"], straight_stake, outside_stake
    if strategy == "Even only":
        return [], ["Even"], straight_stake, outside_stake
    if strategy == "Odd only":
        return [], ["Odd"], straight_stake, outside_stake
    if strategy == "Column 1 only":
        return [], ["Column 1"], straight_stake, outside_stake
    if strategy == "Column 2 only":
        return [], ["Column 2"], straight_stake, outside_stake
    if strategy == "Column 3 only":
        return [], ["Column 3"], straight_stake, outside_stake
    return current_numbers, current_outside_bets, straight_stake, outside_stake


def calculate_max_drawdown(history: list[int]) -> float:
    if not history:
        return 0.0
    peak = history[0]
    max_drawdown = 0.0
    for value in history:
        if value > peak:
            peak = value
        if peak > 0:
            drawdown = (peak - value) / peak
            if drawdown > max_drawdown:
                max_drawdown = drawdown
    return max_drawdown * 100


def calculate_streaks(net_results: list[int]) -> tuple[int, int]:
    longest_winning = 0
    longest_losing = 0
    current_winning = 0
    current_losing = 0

    for net in net_results:
        if net > 0:
            current_winning += 1
            current_losing = 0
        else:
            current_losing += 1
            current_winning = 0

        if current_winning > longest_winning:
            longest_winning = current_winning
        if current_losing > longest_losing:
            longest_losing = current_losing

    return longest_winning, longest_losing


def simulate_games(
    spins_to_run: int,
    strategy: str,
    starting_bankroll: int,
    current_numbers: list[int],
    current_outside_bets: list[str],
    straight_stake: int,
    outside_stake: int,
) -> dict[str, float | int | str | list[int] | bool]:
    straight_numbers, outside_bets, straight_stake, outside_stake = strategy_to_bets(
        strategy,
        current_numbers,
        current_outside_bets,
        straight_stake,
        outside_stake,
    )
    total_bet = len(straight_numbers) * straight_stake + len(outside_bets) * outside_stake

    bankroll = starting_bankroll
    hit_spins = 0
    profitable_spins = 0
    bankroll_history = [bankroll]
    actual_spins = 0
    net_results: list[int] = []
    total_wagered = 0
    best_bankroll = bankroll
    worst_bankroll = bankroll

    if total_bet <= 0:
        return {
            "strategy": strategy,
            "spins": spins_to_run,
            "actual_spins": 0,
            "ending_bankroll": bankroll,
            "net_profit": 0,
            "hit_rate": 0.0,
            "profit_rate": 0.0,
            "average_net": 0.0,
            "total_bet": total_bet,
            "total_wagered": 0,
            "roi": 0.0,
            "bankroll_history": bankroll_history,
            "bust": False,
            "best_bankroll": bankroll,
            "worst_bankroll": bankroll,
            "max_drawdown": 0.0,
            "longest_winning_streak": 0,
            "longest_losing_streak": 0,
        }

    for _ in range(spins_to_run):
        if bankroll < total_bet:
            break

        number = spin_wheel()
        total_return, winning_bets, _ = resolve_spin(
            number,
            straight_numbers,
            straight_stake,
            outside_bets,
            outside_stake,
        )
        net = total_return - total_bet

        bankroll += net
        total_wagered += total_bet
        bankroll_history.append(bankroll)
        net_results.append(net)
        actual_spins += 1

        if winning_bets:
            hit_spins += 1
        if net > 0:
            profitable_spins += 1

        if bankroll > best_bankroll:
            best_bankroll = bankroll
        if bankroll < worst_bankroll:
            worst_bankroll = bankroll

    denominator = actual_spins if actual_spins > 0 else 1
    longest_winning_streak, longest_losing_streak = calculate_streaks(net_results)
    roi = 0.0 if total_wagered == 0 else ((bankroll - starting_bankroll) / total_wagered) * 100
    max_drawdown = calculate_max_drawdown(bankroll_history)

    return {
        "strategy": strategy,
        "spins": spins_to_run,
        "actual_spins": actual_spins,
        "ending_bankroll": bankroll,
        "net_profit": bankroll - starting_bankroll,
        "hit_rate": (hit_spins / denominator) * 100,
        "profit_rate": (profitable_spins / denominator) * 100,
        "average_net": (bankroll - starting_bankroll) / denominator,
        "total_bet": total_bet,
        "total_wagered": total_wagered,
        "roi": roi,
        "bankroll_history": bankroll_history,
        "bust": actual_spins < spins_to_run,
        "best_bankroll": best_bankroll,
        "worst_bankroll": worst_bankroll,
        "max_drawdown": max_drawdown,
        "longest_winning_streak": longest_winning_streak,
        "longest_losing_streak": longest_losing_streak,
    }


def percentile(sorted_values: list[int], q: float) -> float:
    if not sorted_values:
        return 0.0
    if len(sorted_values) == 1:
        return float(sorted_values[0])

    position = (len(sorted_values) - 1) * q
    lower = int(math.floor(position))
    upper = int(math.ceil(position))
    if lower == upper:
        return float(sorted_values[lower])

    weight = position - lower
    return sorted_values[lower] * (1 - weight) + sorted_values[upper] * weight


def run_monte_carlo(
    num_runs: int,
    spins_to_run: int,
    strategy: str,
    starting_bankroll: int,
    current_numbers: list[int],
    current_outside_bets: list[str],
    straight_stake: int,
    outside_stake: int,
) -> dict[str, object]:
    run_results = []
    final_bankrolls = []
    profits = []
    drawdowns = []
    bust_count = 0
    profit_finish_count = 0

    for _ in range(num_runs):
        result = simulate_games(
            spins_to_run,
            strategy,
            starting_bankroll,
            current_numbers,
            current_outside_bets,
            straight_stake,
            outside_stake,
        )
        run_results.append(result)
        final_bankrolls.append(int(result["ending_bankroll"]))
        profits.append(int(result["net_profit"]))
        drawdowns.append(float(result["max_drawdown"]))

        if result["bust"]:
            bust_count += 1
        if int(result["ending_bankroll"]) > starting_bankroll:
            profit_finish_count += 1

    final_bankrolls_sorted = sorted(final_bankrolls)
    profits_sorted = sorted(profits)

    average_final_bankroll = sum(final_bankrolls) / len(final_bankrolls) if final_bankrolls else 0.0
    average_profit = sum(profits) / len(profits) if profits else 0.0
    average_drawdown = sum(drawdowns) / len(drawdowns) if drawdowns else 0.0

    histogram_data = [{"final_bankroll": value} for value in final_bankrolls]
    sample_path = []
    if run_results:
        sample_path = downsample_history(run_results[0]["bankroll_history"])

    return {
        "num_runs": num_runs,
        "average_final_bankroll": average_final_bankroll,
        "average_profit": average_profit,
        "average_drawdown": average_drawdown,
        "bust_probability": (bust_count / num_runs) * 100 if num_runs else 0.0,
        "profit_finish_probability": (profit_finish_count / num_runs) * 100 if num_runs else 0.0,
        "min_final_bankroll": min(final_bankrolls) if final_bankrolls else 0,
        "max_final_bankroll": max(final_bankrolls) if final_bankrolls else 0,
        "p5_final_bankroll": percentile(final_bankrolls_sorted, 0.05),
        "p50_final_bankroll": percentile(final_bankrolls_sorted, 0.50),
        "p95_final_bankroll": percentile(final_bankrolls_sorted, 0.95),
        "p5_profit": percentile(profits_sorted, 0.05),
        "p50_profit": percentile(profits_sorted, 0.50),
        "p95_profit": percentile(profits_sorted, 0.95),
        "histogram_data": histogram_data,
        "sample_path": sample_path,
    }


def downsample_history(history: list[int], max_points: int = 500) -> list[dict[str, int]]:
    indexed = [{"spin": idx, "bankroll": value} for idx, value in enumerate(history)]
    if len(indexed) <= max_points:
        return indexed
    step = max(1, len(indexed) // max_points)
    sampled = indexed[::step]
    if sampled[-1]["spin"] != indexed[-1]["spin"]:
        sampled.append(indexed[-1])
    return sampled


def polar_to_cartesian(cx: float, cy: float, radius: float, angle_deg: float) -> tuple[float, float]:
    angle_rad = math.radians(angle_deg - 90)
    return cx + radius * math.cos(angle_rad), cy + radius * math.sin(angle_rad)


def build_wheel_svg(winning_number: int | None) -> str:
    center = 180
    radius_outer = 168
    radius_inner = 102
    angle_step = 360 / len(WHEEL_ORDER)
    segments = []

    for index, number in enumerate(WHEEL_ORDER):
        start = index * angle_step
        end = start + angle_step
        x1, y1 = polar_to_cartesian(center, center, radius_outer, end)
        x2, y2 = polar_to_cartesian(center, center, radius_outer, start)
        x3, y3 = polar_to_cartesian(center, center, radius_inner, start)
        x4, y4 = polar_to_cartesian(center, center, radius_inner, end)

        fill = "#1da15c" if number == 0 else "#d73a32" if number in RED_NUMBERS else "#101010"
        stroke = "#f4d37c" if number == winning_number else "rgba(255,255,255,0.2)"
        stroke_width = 4 if number == winning_number else 1.2

        mid_angle = start + angle_step / 2
        tx, ty = polar_to_cartesian(center, center, 133, mid_angle)

        segments.append(
            f"""
            <path d="M {x1:.2f} {y1:.2f}
                     A {radius_outer} {radius_outer} 0 0 0 {x2:.2f} {y2:.2f}
                     L {x3:.2f} {y3:.2f}
                     A {radius_inner} {radius_inner} 0 0 1 {x4:.2f} {y4:.2f} Z"
                  fill="{fill}" stroke="{stroke}" stroke-width="{stroke_width}"></path>
            <text x="{tx:.2f}" y="{ty:.2f}" fill="#fff7d3" font-size="13" font-weight="700"
                  text-anchor="middle" dominant-baseline="middle">{number}</text>
            """
        )

    winner_label = "--" if winning_number is None else str(winning_number)
    return f"""
    <svg viewBox="0 0 360 360" width="100%" aria-label="Roulette wheel">
        <defs>
            <radialGradient id="felt" cx="50%" cy="45%">
                <stop offset="0%" stop-color="#2d8b59"></stop>
                <stop offset="100%" stop-color="#123c2c"></stop>
            </radialGradient>
        </defs>
        <circle cx="180" cy="180" r="178" fill="#6b4b18" stroke="#f2d37b" stroke-width="4"></circle>
        {''.join(segments)}
        <circle cx="180" cy="180" r="92" fill="url(#felt)" stroke="#f2d37b" stroke-width="8"></circle>
        <circle cx="180" cy="180" r="20" fill="#f2d37b"></circle>
        <polygon points="180,18 192,42 168,42" fill="#f7f0d0" stroke="#765116" stroke-width="2"></polygon>
        <text x="180" y="170" text-anchor="middle" fill="#fff7d3" font-size="14" opacity="0.85">WINNER</text>
        <text x="180" y="198" text-anchor="middle" fill="#fff7d3" font-size="34" font-weight="800">{winner_label}</text>
    </svg>
    """


